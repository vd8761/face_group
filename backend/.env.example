# Application security
SECRET_KEY=replace-with-a-random-64-character-secret
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password
DEBUG=false

# PostgreSQL / Neon (the driver is normalized to asyncpg automatically)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=face-group
# R2_PUBLIC_URL=https://cdn.example.com

# Redis / Upstash (used by Celery and transient live telemetry)
REDIS_URL=rediss://default:token@host:6380

# Optional Google Drive folder import
# GOOGLE_DRIVE_API_KEY=your-google-api-key

# Browser origins as a JSON array
CORS_ORIGINS=["http://localhost:5173"]

# Face pipeline defaults are intentionally pinned. Change the model only when
# you will reprocess every existing photo; embeddings from different models
# must not be compared.
INSIGHTFACE_MODEL=buffalo_l
FACE_PIPELINE_VERSION=insightface-buffalo-l-v2
INSIGHTFACE_HOME=~/.insightface
FACE_DETECTION_SIZE=1024
FACE_ENABLE_TILING=true

# Ubuntu/Linux face workers start at one prefork child and may grow one child
# at a time. Each child owns a separate Buffalo-L CUDA model. Keep the defaults
# for 4 GB GPUs; larger dedicated GPUs can raise the hard maximum only after a
# representative soak test. Windows always uses Celery's solo pool at one.
WORKER_AUTOSCALE_ENABLED=true
WORKER_AUTOSCALE_MIN_CONCURRENCY=1
WORKER_AUTOSCALE_MAX_CONCURRENCY=4
# Fail closed at one when no GPU/NVML is visible; raise only for sized CPU hosts.
WORKER_AUTOSCALE_CPU_MAX_CONCURRENCY=1
WORKER_AUTOSCALE_GPU_DEVICE_INDEX=0
WORKER_AUTOSCALE_GPU_MEMORY_PER_PROCESS_MB=1800
WORKER_AUTOSCALE_GPU_MEMORY_RESERVE_MB=1024
WORKER_AUTOSCALE_SYSTEM_MEMORY_PER_PROCESS_MB=1800
WORKER_AUTOSCALE_SYSTEM_MEMORY_RESERVE_MB=768
WORKER_AUTOSCALE_GPU_GROW_PERCENT=72
WORKER_AUTOSCALE_CPU_GROW_PERCENT=75
WORKER_AUTOSCALE_CPU_SHRINK_PERCENT=92
WORKER_AUTOSCALE_SAMPLE_INTERVAL_SECONDS=2
WORKER_AUTOSCALE_GROW_SAMPLES=3
WORKER_AUTOSCALE_SCALE_UP_COOLDOWN_SECONDS=15
WORKER_AUTOSCALE_IDLE_SECONDS=20
WORKER_AUTOSCALE_SCALE_DOWN_COOLDOWN_SECONDS=30
