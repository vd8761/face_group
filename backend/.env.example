# Application security
SECRET_KEY=replace-with-a-random-64-character-secret
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password
DEBUG=false

# PostgreSQL / Neon (the driver is normalized to asyncpg automatically)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=face-group
# R2_PUBLIC_URL=https://cdn.example.com

# Redis / Upstash (used by Celery and transient live telemetry)
REDIS_URL=rediss://default:token@host:6380

# Optional Google Drive folder import
# GOOGLE_DRIVE_API_KEY=your-google-api-key

# Browser origins as a JSON array
CORS_ORIGINS=["http://localhost:5173"]

# Face pipeline defaults are intentionally pinned. Change the model only when
# you will reprocess every existing photo; embeddings from different models
# must not be compared.
INSIGHTFACE_MODEL=buffalo_l
FACE_PIPELINE_VERSION=insightface-buffalo-l-v2
INSIGHTFACE_HOME=~/.insightface
FACE_DETECTION_SIZE=1024
FACE_ENABLE_TILING=true
